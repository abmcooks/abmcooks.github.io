---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Basit Masood — Head of Product Design. Two-time founding designer. Fintech." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <ClientRouter />

  <!-- Fontshare: JetBrains Mono -->
  <link href="https://api.fontshare.com/v2/css?f[]=jet-brains-mono@400,700&display=swap" rel="stylesheet" />

  <!-- Phosphor Icons (CSS) -->
  <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/bold/style.css" />

  <!-- Umami Analytics -->
  <script defer src="https://cloud.umami.is/script.js" data-website-id="dcd588fe-7465-4f25-b904-c044d2a17532"></script>

  <slot name="head" />
</head>
<body>
  <slot />

  <script>
    // Site-wide nav behavior — backdrop + hide-on-scroll.
    // Nav items stay white site-wide; dark scrolled backdrop handles contrast.
    (function(){
      let nav = null;
      let ls = 0;
      function bind(){
        nav = document.querySelector('.nav');
        update();
      }
      function update(){
        if(!nav) return;
        const c = window.scrollY;
        if(c > ls && c > 100) nav.classList.add('nav-hidden');
        else if(c < ls) nav.classList.remove('nav-hidden');
        if(c > 40) nav.classList.add('nav-scrolled');
        else nav.classList.remove('nav-scrolled');
        ls = c;
      }
      bind();
      document.addEventListener('DOMContentLoaded', bind);
      document.addEventListener('astro:page-load', bind);
      window.addEventListener('scroll', update, { passive: true });
    })();
  </script>
</body>
</html>
