<script>
  // Cursor
  const cursor = document.getElementById('customCursor');
  if (cursor && window.matchMedia('(pointer: fine)').matches) {
    let mouseX=0,mouseY=0,curX=0,curY=0;
    document.addEventListener('mousemove',(e)=>{mouseX=e.clientX;mouseY=e.clientY;});
    function ac(){curX+=(mouseX-curX)*0.15;curY+=(mouseY-curY)*0.15;cursor.style.transform=`translate(${curX}px,${curY}px)`;requestAnimationFrame(ac);}
    ac(); document.body.classList.add('cursor-active');
    document.querySelectorAll('a,button').forEach(el=>{el.addEventListener('mouseenter',()=>cursor.classList.add('hover'));el.addEventListener('mouseleave',()=>cursor.classList.remove('hover'));});
  }
  // Nav hide
  let ls=0; const nav=document.getElementById('nav');
  window.addEventListener('scroll',()=>{const c=window.scrollY;if(c>ls&&c>100)nav?.classList.add('nav-hidden');else nav?.classList.remove('nav-hidden');ls=c;},{passive:true});
  // Menu
  const burger=document.getElementById('navBurger'),fsMenu=document.getElementById('fsMenu'),fsClose=document.getElementById('fsMenuClose');
  if(burger&&fsMenu){burger.addEventListener('click',()=>{fsMenu.classList.add('open');document.body.style.overflow='hidden';});fsClose?.addEventListener('click',()=>{fsMenu.classList.remove('open');document.body.style.overflow='';});fsMenu.querySelectorAll('.fs-menu-link').forEach(l=>l.addEventListener('click',()=>{fsMenu.classList.remove('open');document.body.style.overflow='';}));}
  // Loader
  const loader=document.getElementById('loader');if(loader){setTimeout(()=>{loader.classList.add('done');document.body.classList.add('loaded');},2400);}
  // Reveal
  const io=new IntersectionObserver((entries)=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('revealed');io.unobserve(e.target);}});},{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
  if(window.matchMedia('(prefers-reduced-motion: reduce)').matches){document.querySelectorAll('.reveal').forEach(el=>el.classList.add('revealed'));}
  // Testimonial carousel arrows
  const track=document.getElementById('testiTrack');
  const prevBtn=document.getElementById('testiPrev');
  const nextBtn=document.getElementById('testiNext');
  if(track&&prevBtn&&nextBtn){
    const scrollAmt=424;
    prevBtn.addEventListener('click',()=>track.scrollBy({left:-scrollAmt,behavior:'smooth'}));
    nextBtn.addEventListener('click',()=>track.scrollBy({left:scrollAmt,behavior:'smooth'}));
  }
</script>

