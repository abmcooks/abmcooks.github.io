<!-- ═══ HERO — Clean, product-focused ═══ -->
<section class="sp-hero">
  <div class="sp-hero-inner reveal">
    <div class="sp-hero-content">
      <a href="/stories" class="sp-hero-back"><i class="ph-bold ph-arrow-left"></i> All Stories</a>
      <p class="sp-hero-eyebrow">ADIB · Sep 2024 – Feb 2025 · Lead Product Designer</p>
      <h1 class="sp-hero-title">REAL-TIME CROSS-BORDER TRANSFERS FOR THE MIDDLE EAST'S LEADING ISLAMIC BANK.</h1>
      <p class="sp-hero-desc">Six months at Abu Dhabi Islamic Bank. Designed Remit! (Visa Direct), open banking UI/UX, and overhauled the design system from chaotic to atomic.</p>
    </div>
    <div class="sp-hero-visual">
      <!-- Replace with product screenshot: <img src="/images/adib-hero.png" alt="ADIB app" /> -->
    </div>
  </div>
</section>

<!-- ═══ STATS — Grid cards ═══ -->
<section class="sp-stats">
  <div class="sp-stats-inner reveal">
    <div class="sp-stat">
      <span class="sp-stat-val">1M+</span>
      <span class="sp-stat-label">App users</span>
    </div>
