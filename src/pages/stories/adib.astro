---
import Base from '../../layouts/Base.astro';
import Loader from '../../components/Loader.astro';
import Cursor from '../../components/Cursor.astro';
import Nav from '../../components/Nav.astro';
import FsMenu from '../../components/FsMenu.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import '../../styles/stories.css';
---

<Base title="ADIB — Basit Masood" description="Real-time cross-border transfers for the Middle East's leading Islamic bank. Remit! by Visa Direct, open banking, and design system overhaul.">

<script is:inline>
  (function(){
    var apply = function(){ document.body && document.body.classList.add('page-light'); };
    var clear = function(){ document.body && document.body.classList.remove('page-light'); };
    apply();
    document.addEventListener('astro:page-load', apply);
    document.addEventListener('astro:after-swap', apply);
    document.addEventListener('astro:before-swap', clear);
  })();
</script>

<Loader />
<Cursor />
<Nav active="stories" />
<FsMenu />

<!-- ═══════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════ -->
<section class="sp2-hero">
  <div class="sp2-hero-inner">
    <p class="sp2-hero-eyebrow">ADIB · Lead Product Designer · Sep 2024 – Feb 2025</p>
    <h1 class="sp2-hero-primary">Cross-border, real-time.</h1>
    <p class="sp2-hero-secondary">Remit! by Visa Direct for the Middle East's leading Islamic bank.</p>
    <p class="sp2-hero-desc">Six months at Abu Dhabi Islamic Bank — a 1.5 million-customer institution with 80% digital adoption and Euromoney's Best Islamic Bank 2025. I shipped three strategic initiatives: Remit! (Visa Direct cross-border), UAE Open Banking UI/UX, and a design-system overhaul. Short tenure, meaningful work.</p>
  </div>
  <span class="sp2-hero-scroll">Scroll</span>
</section>

<!-- ═══════════════════════════════════════════
     BRAND MOMENT
     ═══════════════════════════════════════════ -->
<section class="sb-brand">
  <div class="sb-brand-inner">
    <img src="/images/ADIB-full-logo.svg" alt="Abu Dhabi Islamic Bank" class="sb-brand-logo" />
    <div class="sb-brand-rule"></div>
    <p class="sb-brand-caption">Abu Dhabi Islamic Bank · UAE · Since 1997</p>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     STAKES · CONTEXT
     ═══════════════════════════════════════════ -->
<section class="sp2-stakes">
  <div class="sp2-stakes-inner">
    <div class="sp2-stakes-layout">
      <div class="sp2-stakes-stats">
        <div class="sp2-stakes-hero-stat">
          <span class="val">1M+</span>
          <span class="label">App users</span>
        </div>
        <div class="sp2-stakes-supporting">
          <div class="stat"><span class="val">1.5M</span><span class="label">Customers</span></div>
          <div class="stat"><span class="val">80%</span><span class="label">Digital adoption</span></div>
          <div class="stat"><span class="val">Euromoney</span><span class="label">Best Islamic Bank 2025</span></div>
        </div>
      </div>
      <div class="sp2-stakes-context">
        <h2>The flagship Islamic bank<br/>meets <span class="accent">real-time remittance</span>.</h2>
        <p>ADIB's customer base spans the UAE's expat majority — workers sending money home to Egypt, Pakistan, India, the Philippines. The remittance product they had was branch-era: slow, corridor-limited, and priced against regional challengers. The brief was to build the real-time digital version on top of Visa Direct's global rails.</p>
        <p>I joined as Lead Product Designer on the most strategic digital initiative of the year — and on two parallel tracks that touched the rest of the bank: UAE's emerging Open Banking regulation, and the internal design system.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     THE WORK
     ═══════════════════════════════════════════ -->
<section class="sb-work">
  <div class="sb-work-head">
    <p class="sb-work-eyebrow">What I did</p>
    <h2 class="sb-work-heading">Three tracks, six months.</h2>
  </div>
  <div class="sb-work-grid">
    <div class="sb-work-item">
      <span class="sb-work-tag">Remit! · Visa Direct</span>
      <h3 class="sb-work-title">Cross-border, end-to-end.</h3>
      <p class="sb-work-body">Full Remit! experience — recipients, transfer flow, live FX and fee transparency, confirmation, error handling. Dozens of corridors on Visa Direct's 11B-card rail. Every screen shipped live; no staging for regulated flows.</p>
    </div>
    <div class="sb-work-item">
      <span class="sb-work-tag">Open Banking</span>
      <h3 class="sb-work-title">UAE Open Finance, from scratch.</h3>
      <p class="sb-work-body">UI/UX for the UAE's emerging Open Finance regulation — aggregation, consent, third-party sharing. No regional precedent. Balanced compliance with usability for customers never before asked to grant an app read-access to their bank.</p>
    </div>
    <div class="sb-work-item">
      <span class="sb-work-tag">Design system overhaul</span>
      <h3 class="sb-work-title">From chaotic to atomic.</h3>
      <p class="sb-work-body">Full restructure of a system fragmented by years of parallel squads — token architecture, atomic primitives, governed patterns. Became the substrate other product teams shipped on for the rest of the year.</p>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     TESTIMONIALS
     ═══════════════════════════════════════════ -->
<section class="sp2-testi">
  <div class="sp2-testi-head">
    <h2>What they said</h2>
    <div class="sp2-testi-arrows">
      <button class="sp2-testi-arrow" id="testiPrev" aria-label="Previous"><span class="sp2-arrow">←</span></button>
      <button class="sp2-testi-arrow" id="testiNext" aria-label="Next"><span class="sp2-arrow">→</span></button>
    </div>
  </div>
  <div class="sp2-testi-track" id="testiTrack">
    <div class="sp2-testi-card">
      <div class="sp2-testi-mark">&#8220;</div>
      <blockquote class="sp2-testi-quote">Although short, his impact was truly significant.</blockquote>
      <div class="sp2-testi-attribution">
        <span class="sp2-testi-name">Daniel Young</span>
        <span class="sp2-testi-role">ADIB</span>
      </div>
    </div>
    <div class="sp2-testi-card">
      <div class="sp2-testi-mark">&#8220;</div>
      <blockquote class="sp2-testi-quote">He added value from day one. He's a fearless problem solver.</blockquote>
      <div class="sp2-testi-attribution">
        <span class="sp2-testi-name">Batsi Madzonga</span>
        <span class="sp2-testi-role">ADIB</span>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     NEXT
     ═══════════════════════════════════════════ -->
<section class="sp2-next">
  <div class="sp2-next-back"><a href="/stories"><span class="sp2-arrow">←</span> Back to all stories</a></div>
  <a href="/stories/bolt-vpn" class="sp2-next-cta">
    <span class="label">Next Story</span>
    <span class="title">Bolt VPN <span class="sp2-arrow">→</span></span>
  </a>
</section>

<Footer />

<script>
  function initBrief() {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
    }

    const track = document.getElementById('testiTrack');
    const prevBtn = document.getElementById('testiPrev');
    const nextBtn = document.getElementById('testiNext');
    if (track && prevBtn && nextBtn) {
      function getScrollAmt() {
        const card = track.querySelector('.sp2-testi-card') as HTMLElement | null;
        if (!card) return 464;
        return card.offsetWidth + 24;
      }
      prevBtn.addEventListener('click', () => track.scrollBy({ left: -getScrollAmt(), behavior: 'smooth' }));
      nextBtn.addEventListener('click', () => track.scrollBy({ left: getScrollAmt(), behavior: 'smooth' }));
    }
  }
  initBrief();
  document.addEventListener('astro:page-load', initBrief);
</script>

</Base>
