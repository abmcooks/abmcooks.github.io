---
import Base from '../../layouts/Base.astro';
import Loader from '../../components/Loader.astro';
import Cursor from '../../components/Cursor.astro';
import Nav from '../../components/Nav.astro';
import FsMenu from '../../components/FsMenu.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import '../../styles/stories.css';
---

<Base title="Bolt VPN — Basit Masood" description="UI/UX transformation and paywall optimization for a 25M+ download VPN app. Via Galixo AI.">

<script is:inline>
  (function(){
    var apply = function(){ document.body && document.body.classList.add('page-light'); };
    var clear = function(){ document.body && document.body.classList.remove('page-light'); };
    apply();
    document.addEventListener('astro:page-load', apply);
    document.addEventListener('astro:after-swap', apply);
    document.addEventListener('astro:before-swap', clear);
  })();
</script>

<Loader />
<Cursor />
<Nav active="stories" />
<FsMenu />

<!-- ═══════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════ -->
<section class="sp2-hero">
  <div class="sp2-hero-inner">
    <p class="sp2-hero-eyebrow">Bolt VPN via Galixo AI · Lead Product Design Consultant · 2023</p>
    <h1 class="sp2-hero-primary">25 million downloads.</h1>
    <p class="sp2-hero-secondary">A VPN app that needed to look like it earned them.</p>
    <p class="sp2-hero-desc">Bolt VPN had the scale but not the polish — a dated interface bleeding conversion to slicker competitors. I was brought in through Galixo AI to rebuild the brand, the product, and the paywall flow that drives the subscription business.</p>
  </div>
  <span class="sp2-hero-scroll">Scroll</span>
</section>

<!-- ═══════════════════════════════════════════
     BRAND MOMENT
     ═══════════════════════════════════════════ -->
<section class="sb-brand">
  <div class="sb-brand-inner">
    <img src="/images/boltvpn-logo.png" alt="Bolt VPN" class="sb-brand-logo sb-brand-logo--dark" />
    <div class="sb-brand-rule"></div>
    <p class="sb-brand-caption">Bolt VPN · Consumer app · Global</p>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     STAKES · CONTEXT
     ═══════════════════════════════════════════ -->
<section class="sp2-stakes">
  <div class="sp2-stakes-inner">
    <div class="sp2-stakes-layout">
      <div class="sp2-stakes-stats">
        <div class="sp2-stakes-hero-stat">
          <span class="val">25M+</span>
          <span class="label">Downloads</span>
        </div>
        <div class="sp2-stakes-supporting">
          <div class="stat"><span class="val">Global</span><span class="label">User base</span></div>
          <div class="stat"><span class="val">Galixo AI</span><span class="label">Studio partner</span></div>
          <div class="stat"><span class="val">Full stack</span><span class="label">Brand + UX + paywall</span></div>
        </div>
      </div>
      <div class="sp2-stakes-context">
        <h2>The scale was there.<br/><span class="accent">The product</span> wasn't keeping up.</h2>
        <p>Bolt VPN had reached 25 million downloads on a dated interface — one-tap connect was hidden behind two tap-throughs, server selection was a wall of flags, and the paywall was doing the bare minimum to convert users who'd already decided to subscribe. The category had moved; the product hadn't.</p>
        <p>The brief was end-to-end: complete visual overhaul, UI/UX redesign of every core flow, and a paywall rebuild calibrated to lift subscription conversion without sacrificing the "free and fast" promise that drove downloads in the first place.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     THE WORK
     ═══════════════════════════════════════════ -->
<section class="sb-work">
  <div class="sb-work-head">
    <p class="sb-work-eyebrow">What I did</p>
    <h2 class="sb-work-heading">Three layers, rebuilt in parallel.</h2>
  </div>
  <div class="sb-work-grid">
    <div class="sb-work-item">
      <span class="sb-work-tag">Brand overhaul</span>
      <h3 class="sb-work-title">A VPN that looked the part.</h3>
      <p class="sb-work-body">Rebuilt the brand from the logo out — typography, colour, iconography, motion. The old identity read "free utility app"; the new one signals "subscription-grade product you'd pay for." Modern and confident, no cyberpunk cliché.</p>
    </div>
    <div class="sb-work-item">
      <span class="sb-work-tag">Core UX redesign</span>
      <h3 class="sb-work-title">One tap to connect.</h3>
      <p class="sb-work-body">Redesigned connection flow, server selection, and status UI. A user who just wants VPN-on never thinks about the app; a user wanting server control gets there in two taps. Visual server status, grouped country tiles, instant-feedback motion.</p>
    </div>
    <div class="sb-work-item">
      <span class="sb-work-tag">Paywall optimization</span>
      <h3 class="sb-work-title">Conversion without coercion.</h3>
      <p class="sb-work-body">Rebuilt the paywall around price clarity, plan comparison, and a trial that felt like opportunity, not trap. No dark patterns, no fake urgency. Conversion lifted because the upgrade was easier to understand, not because friction forced it.</p>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     NEXT
     ═══════════════════════════════════════════ -->
<section class="sp2-next">
  <div class="sp2-next-back"><a href="/stories"><span class="sp2-arrow">←</span> Back to all stories</a></div>
  <a href="/stories/gosaas" class="sp2-next-cta">
    <span class="label">Next Story</span>
    <span class="title">GoCompliance <span class="sp2-arrow">→</span></span>
  </a>
</section>

<Footer />

<script>
  function initBrief() {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
    }
  }
  initBrief();
  document.addEventListener('astro:page-load', initBrief);
</script>

</Base>
