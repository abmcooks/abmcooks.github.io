---
import Base from '../../layouts/Base.astro';
import Loader from '../../components/Loader.astro';
import Cursor from '../../components/Cursor.astro';
import Nav from '../../components/Nav.astro';
import FsMenu from '../../components/FsMenu.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import '../../styles/stories.css';
---

<Base title="Stories — Basit Masood" description="Thirty products shipped. Six million users. Two acquisitions. The work of Basit Masood.">

<script is:inline>
  // Light-mode + page-specific class (for scroll-snap behavior)
  (function(){
    var apply = function(){
      if (!document.body) return;
      document.body.classList.add('page-light');
      document.body.classList.add('stories-landing');
      document.documentElement.classList.add('stories-landing');
    };
    var clear = function(){
      if (!document.body) return;
      document.body.classList.remove('page-light');
      document.body.classList.remove('stories-landing');
      document.documentElement.classList.remove('stories-landing');
    };
    apply();
    document.addEventListener('astro:page-load', apply);
    document.addEventListener('astro:after-swap', apply);
    document.addEventListener('astro:before-swap', clear);
  })();
</script>

<Loader />
<Cursor />
<Nav active="stories" />
<FsMenu />

<!-- ═══════════════════════════════════════════
     HERO — glass panel over soft atmospheric wash
     ═══════════════════════════════════════════ -->
<section class="sti-hero">

  <!-- Architectural dot-grid backdrop — gives glass something real to blur -->
  <div class="sti-atmosphere" aria-hidden="true"></div>

  <!-- Glass panel — the anchor -->
  <div class="sti-hero-center">
    <p class="sti-hero-kicker">
      <span class="sti-kicker-rule"></span>
      <span>Selected work · 2016 – Present</span>
    </p>
    <h1 class="sti-hero-title">Hall of fame.</h1>
    <div class="sti-hero-stats">
      <div><strong>30+</strong><span>Products</span></div>
      <div><strong>6M+</strong><span>Users</span></div>
      <div><strong>110+</strong><span>Countries</span></div>
      <div><strong>2</strong><span>Exits</span></div>
    </div>
  </div>

  <span class="sti-hero-scroll">Scroll</span>
</section>

