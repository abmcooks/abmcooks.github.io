<script>
  // Page-specific behavior. Loader/Cursor/Nav-scroll/FsMenu live in shared components now.
  function initSadaPay() {
    // Scroll reveal for .reveal elements
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
    }

    // Video audio toggle
    const video = document.getElementById('sp2LaunchVideo') as HTMLVideoElement | null;
    const audioBtn = document.getElementById('sp2VideoAudio');
    if (video && audioBtn) {
      audioBtn.addEventListener('click', () => {
        video.muted = !video.muted;
        const icon = audioBtn.querySelector('i');
        const label = audioBtn.querySelector('span');
        if (video.muted) {
          if (icon) icon.className = 'ph-bold ph-speaker-simple-slash';
          if (label) label.textContent = 'Sound off';
        } else {
          if (icon) icon.className = 'ph-bold ph-speaker-simple-high';
          if (label) label.textContent = 'Sound on';
        }
      });
    }

    // Testimonial carousel arrows
    const track = document.getElementById('testiTrack');
    const prevBtn = document.getElementById('testiPrev');
    const nextBtn = document.getElementById('testiNext');
    if (track && prevBtn && nextBtn) {
      function getScrollAmt() {
        const card = track.querySelector('.sp2-testi-card') as HTMLElement | null;
        if (!card) return 464;
        return card.offsetWidth + 24;
      }
      prevBtn.addEventListener('click', () => track.scrollBy({ left: -getScrollAmt(), behavior: 'smooth' }));
      nextBtn.addEventListener('click', () => track.scrollBy({ left: getScrollAmt(), behavior: 'smooth' }));
    }
  }
  initSadaPay();
  document.addEventListener('astro:page-load', initSadaPay);
</script>

