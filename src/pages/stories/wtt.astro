---
import Base from '../../layouts/Base.astro';
import Loader from '../../components/Loader.astro';
import Cursor from '../../components/Cursor.astro';
import Nav from '../../components/Nav.astro';
import FsMenu from '../../components/FsMenu.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import '../../styles/stories.css';
---

<Base title="Walking the Talk — Basit Masood" description="Lead Product Design Consultant for the world's largest culture-only consulting firm. Six tools, 200 organizations, acquired by ZRG Partners.">

<script is:inline>
  // Light-mode page class — only on this page
  (function(){
    var apply = function(){ document.body && document.body.classList.add('page-light'); };
    var clear = function(){ document.body && document.body.classList.remove('page-light'); };
    apply();
    document.addEventListener('astro:page-load', apply);
    document.addEventListener('astro:after-swap', apply);
    document.addEventListener('astro:before-swap', clear);
  })();
</script>

<Loader />
<Cursor />
<Nav active="stories" />
<FsMenu />

<!-- ═══════════════════════════════════════════
     ACT I · HERO — Culture, made measurable.
     ═══════════════════════════════════════════ -->
<section class="sp2-hero">
  <div class="sp2-hero-inner">
    <p class="sp2-hero-eyebrow">Walking the Talk · Lead Product Design Consultant · 2023 – 2024</p>
    <h1 class="sp2-hero-primary">Culture, made measurable.</h1>
    <p class="sp2-hero-secondary">Six tools. 200 organizations. Acquired by ZRG.</p>
    <p class="sp2-hero-desc">Walking the Talk is the world's largest culture-only consulting firm — clients run from Visa and Vodafone to Telstra, Westpac, eBay, and Lilly. Their consulting practice was bottlenecked by the tools underneath it. I redesigned their core assessment software into self-serve products that Fortune 500s could use without a consultant on the call — and the firm was acquired by ZRG Partners on the back of that shift.</p>
  </div>
  <span class="sp2-hero-scroll">Scroll</span>
</section>

