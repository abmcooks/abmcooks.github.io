<!-- ═══════════════════════════════════════════
     SCRIPTS
     ═══════════════════════════════════════════ -->
<script>
  // ═══ Custom cursor ═══
  const cursor = document.getElementById('customCursor');
  if (cursor && window.matchMedia('(pointer: fine)').matches) {
    let mouseX = 0, mouseY = 0, curX = 0, curY = 0;
    document.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });
    function animateCursor() {
      curX += (mouseX - curX) * 0.15;
      curY += (mouseY - curY) * 0.15;
      cursor.style.transform = `translate(${curX}px, ${curY}px)`;
      requestAnimationFrame(animateCursor);
    }
    animateCursor();
    document.body.classList.add('cursor-active');
    document.querySelectorAll('a, button, input').forEach((el) => {
      el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
      el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
    });
  }

  // ═══ Nav hide on scroll + AI pill collapse + light/dark detection ═══
  let lastScroll = 0;
  const nav = document.getElementById('nav');
  const aiTriggerEl = document.getElementById('aiTrigger');
  const heroSection = document.getElementById('hero');
  const lightSections = document.querySelectorAll('.testi');

  window.addEventListener('scroll', () => {
    const current = window.scrollY;
    if (current > lastScroll && current > 100) nav?.classList.add('nav-hidden');
    else nav?.classList.remove('nav-hidden');
    lastScroll = current;
    // Collapse AI pill past hero
    if (aiTriggerEl && heroSection) {
      const heroBottom = heroSection.offsetTop + heroSection.offsetHeight;
      if (current > heroBottom - 100) aiTriggerEl.classList.add('collapsed');
      else aiTriggerEl.classList.remove('collapsed');
    }
    // Nav light/dark based on what section is behind it
    let isLight = false;
    lightSections.forEach(sec => {
      const rect = sec.getBoundingClientRect();
      if (rect.top < 60 && rect.bottom > 60) isLight = true;
    });
    if (isLight) {
      nav?.classList.add('nav-light');
      cursor?.classList.add('cursor-dark');
    } else {
      nav?.classList.remove('nav-light');
      cursor?.classList.remove('cursor-dark');
    }
  });

  // ═══ Loader ═══
  const loader = document.getElementById('loader');
  const isReturn = sessionStorage.getItem('loaderSeen');

  function revealPage(skipFlicker) {
    loader?.classList.add('done');
    document.body.classList.add('loaded');
    document.getElementById('nav')?.classList.add('visible');
    document.getElementById('heroContent')?.classList.add('visible');

    if (skipFlicker) {
      document.querySelectorAll('.fl').forEach(el => el.classList.add('on'));
      animateCounters();
    } else {
      const letters = document.querySelectorAll('.fl');
      const flickerers = [];
      letters.forEach(el => {
        if (Math.random() > 0.4) {
          el.classList.add('on');
        } else {
          const dur = 0.8 + Math.random() * 0.4;
          el.style.setProperty('--fd', (Math.random() * 0.3).toFixed(2) + 's');
          el.style.setProperty('--dur', dur.toFixed(2) + 's');
          el.classList.add('go');
          flickerers.push({ el, dur });
        }
      });
      if (flickerers.length) {
        const last = flickerers.reduce((a, b) => a.dur > b.dur ? a : b);
        last.el.style.setProperty('--dur', '1.8s');
      }
      animateCounters();
      setTimeout(() => {
        document.querySelectorAll('.fl').forEach(el => el.classList.add('on'));
      }, 2800);
    }
  }

  // Wait for fonts + hero image before revealing
  function waitForAssets(callback) {
    const heroImg = document.querySelector('.hero-bg-img');
    const fontsReady = document.fonts ? document.fonts.ready : Promise.resolve();
    const imgReady = new Promise(resolve => {
      if (!heroImg || heroImg.complete) resolve();
      else { heroImg.addEventListener('load', resolve); heroImg.addEventListener('error', resolve); }
    });
    Promise.all([fontsReady, imgReady]).then(callback);
    setTimeout(callback, 4000); // safety fallback
  }

  if (loader) {
    sessionStorage.setItem('loaderSeen', '1');
    if (isReturn) {
      // Return visit: wait for assets, no animation delay
      waitForAssets(() => revealPage(true));
    } else {
      // First visit: full brand animation + wait for assets
      const minDelay = new Promise(r => setTimeout(r, 3600));
      const assets = new Promise(r => waitForAssets(r));
      Promise.all([minDelay, assets]).then(() => revealPage(false));
    }
  }

  // ═══ Counter animation ═══
  function animateCounters() {
    document.querySelectorAll('.stat-val[data-count]').forEach((el) => {
      const target = parseFloat(el.dataset.count);
      const prefix = el.dataset.prefix || '';
      const suffix = el.dataset.suffix || '';
      const duration = 2000;
      const start = performance.now();
      function tick(now) {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 4);
        el.textContent = prefix + Math.floor(target * eased) + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    });
  }
  // Counter starts after loader reveals content (called from loader callback)

  // ═══ AI Widget ═══
  const aiTrigger = document.getElementById('aiTrigger');
  const aiPanel = document.getElementById('aiPanel');
  const aiClose = document.getElementById('aiClose');
  if (aiTrigger && aiPanel) {
    aiTrigger.addEventListener('click', () => { aiPanel.classList.toggle('open'); aiTrigger.classList.toggle('hidden'); });
    aiClose?.addEventListener('click', () => { aiPanel.classList.remove('open'); aiTrigger.classList.remove('hidden'); });
  }

  // ═══ Stories — Scroll-driven horizontal carousel ═══
  (function() {
    const section = document.getElementById('stories');
    const track = document.getElementById('storiesTrack');
    const dots = document.querySelectorAll('.stories-dot');
    if (!section || !track) return;

    const panels = track.querySelectorAll('.stories-panel');
    const total = panels.length;

    // Set section height to create scroll room: panels * 100vh
    section.style.height = (total * 100) + 'vh';

    let lastIndex = -1;
    function onScroll() {
      const rect = section.getBoundingClientRect();
      const scrollableHeight = section.offsetHeight - window.innerHeight;
      const scrolled = -rect.top;
      const progress = Math.max(0, Math.min(1, scrolled / scrollableHeight));
      const panelIndex = Math.round(progress * (total - 1));
      track.style.transform = `translateX(-${panelIndex * 100}vw)`;

      // Update progress dots
      if (panelIndex !== lastIndex) {
        lastIndex = panelIndex;
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === panelIndex);
        });
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();

  // ═══ Fullscreen menu ═══
  const burger = document.getElementById('navBurger');
  const fsMenu = document.getElementById('fsMenu');
  const fsClose = document.getElementById('fsMenuClose');
  if (burger && fsMenu) {
    burger.addEventListener('click', () => {
      fsMenu.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
    fsClose?.addEventListener('click', () => {
      fsMenu.classList.remove('open');
      document.body.style.overflow = '';
    });
    // Close on link click
    fsMenu.querySelectorAll('.fs-menu-link').forEach(link => {
      link.addEventListener('click', () => {
        fsMenu.classList.remove('open');
        document.body.style.overflow = '';
      });
    });
  }
</script>

