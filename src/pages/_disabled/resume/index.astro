<style is:global>
  :root {
    --heading: 'Space Grotesk', sans-serif;
    --surface: #ffffff;
    --dim: #6b5d54;
    --muted: #9a8d84;
    --border: rgba(0,0,0,0.08);
    --accent: var(--red);
    --accent-light: #e03e4a;
  }

/* --- PAGE WRAPPER --- */
  .page {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 40px 80px;
  }

  /* --- HEADER --- */
  .header {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }
  .header-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 6px;
  }
  .name {
    font-family: var(--display);
    font-size: 32px;
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: var(--text);
  }
  .title {
    font-family: var(--heading);
    font-size: 14px;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.02em;
    margin-top: 4px;
  }
  .contact {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 20px;
    margin-top: 14px;
  }
  .contact a, .contact span {
    font-size: 12.5px;
    color: var(--dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact a:hover { color: var(--accent-light); }
  .contact .sep { color: var(--muted); }

  /* --- SUMMARY --- */
  .summary {
    font-size: 13.5px;
    color: var(--dim);
    line-height: 1.65;
    max-width: 680px;
  }

  /* --- SECTIONS --- */
  .section {
    margin-top: 36px;
  }
  .section-title {
    font-family: var(--heading);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  /* --- EXPERIENCE ENTRY --- */
  .entry {
    margin-bottom: 28px;
  }
  .entry:last-child { margin-bottom: 0; }
  .entry-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 2px;
  }
  .entry-company {
    font-family: var(--heading);
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .entry-role {
    font-size: 13px;
    font-weight: 500;
    color: var(--dim);
  }
  .entry-meta {
    font-size: 12px;
    color: var(--muted);
    flex-shrink: 0;
  }
  .entry-desc {
    font-size: 13px;
    color: var(--dim);
    margin-top: 4px;
    margin-bottom: 8px;
    font-style: italic;
  }
  .entry ul {
    list-style: none;
    padding: 0;
  }
  .entry li {
    font-size: 13px;
    color: var(--dim);
    line-height: 1.6;
    padding-left: 14px;
    position: relative;
    margin-bottom: 4px;
  }
  .entry li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--muted);
  }

  /* --- CONSULTING --- */
  .consult-entry {
    margin-bottom: 14px;
  }
  .consult-entry:last-child { margin-bottom: 0; }
  .consult-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .consult-name {
    font-family: var(--heading);
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .consult-meta {
    font-size: 11.5px;
    color: var(--muted);
    flex-shrink: 0;
  }
  .consult-desc {
    font-size: 12.5px;
    color: var(--dim);
    line-height: 1.6;
    margin-top: 2px;
  }

  /* --- EXPERTISE --- */
  .expertise-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px 32px;
  }
  .expertise-cat {
    font-family: var(--heading);
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 4px;
    letter-spacing: 0.01em;
  }
  .expertise-items {
    font-size: 12.5px;
    color: var(--dim);
    line-height: 1.6;
  }

  /* --- EDUCATION --- */
  .edu-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  .edu-school {
    font-family: var(--heading);
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
  }
  .edu-degree {
    font-size: 12.5px;
    color: var(--dim);
    margin-top: 2px;
  }
  .edu-year {
    font-size: 12px;
    color: var(--muted);
    flex-shrink: 0;
  }

  /* --- BACK LINK --- */
  .back-link {
    position: fixed;
    top: 24px;
    left: 24px;
    font-family: var(--body);
    font-size: 13px;
    font-weight: 500;
    color: var(--dim);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s;
    z-index: 10;
  }
  .back-link:hover { color: var(--text); }

  .back-link svg { width: 14px; height: 14px; }

  /* --- PRINT BUTTON --- */
  .print-btn {
    position: fixed;
    top: 24px;
    right: 24px;
    font-family: var(--body);
    font-size: 12px;
    font-weight: 600;
    color: var(--dim);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 8px 16px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .print-btn:hover {
    color: var(--text);
    border-color: rgba(0,0,0,0.15);
  }
  .print-btn svg { width: 14px; height: 14px; }

  /* --- MOBILE --- */
  @media (max-width: 640px) {
    .page { padding: 40px 24px 60px; }
    .name { font-size: 26px; }
    .header-top { flex-direction: column; gap: 4px; }
    .entry-header { flex-direction: column; gap: 2px; }
    .consult-header { flex-direction: column; gap: 2px; }
    .expertise-grid { grid-template-columns: 1fr; gap: 14px; }
    .edu-row { flex-direction: column; gap: 2px; }
    body > .back-link, body > .print-btn { display: none; }
    .top-bar { display: flex; justify-content: space-between; margin-bottom: 20px; }
  }

  /* ===================================
     PRINT STYLES
     =================================== */
  @media print {

    html, 

    .page {
      max-width: none;
      padding: 0;
      margin: 0;
    }

    .back-link, .print-btn, .top-bar { display: none !important; }

    .header { margin-bottom: 24px; padding-bottom: 18px; }
    .name { font-size: 26px; }
    .title { font-size: 12px; }
    .contact a, .contact span { font-size: 11px; }
    .summary { font-size: 12px; }

    .section { margin-top: 22px; }
    .section-title { font-size: 10px; margin-bottom: 12px; padding-bottom: 5px; }

    .entry { margin-bottom: 18px; }
    .entry-company { font-size: 14px; }
    .entry-role { font-size: 11.5px; }
    .entry-meta { font-size: 10.5px; }
    .entry-desc { font-size: 11.5px; margin-bottom: 5px; }
    .entry li { font-size: 11.5px; line-height: 1.5; margin-bottom: 2px; padding-left: 12px; }
    .entry li::before { top: 7px; width: 3px; height: 3px; background: #999; }

    .consult-name { font-size: 12.5px; }
    .consult-meta { font-size: 10px; }
    .consult-desc { font-size: 11px; }
    .consult-entry { margin-bottom: 10px; }

    .expertise-grid { gap: 10px 24px; }
    .expertise-cat { font-size: 10.5px; }
    .expertise-items { font-size: 11px; }

    .edu-school { font-size: 12.5px; }
    .edu-degree { font-size: 11px; }
    .edu-year { font-size: 10.5px; }

    /* Avoid page breaks inside individual entries, but allow within sections */
    .entry, .consult-entry { break-inside: avoid; }

    /* Tighten header to let content flow onto page 1 */
    .header { margin-bottom: 16px; padding-bottom: 12px; }
    .summary { margin-top: 10px !important; }
    .section { margin-top: 14px; }
    .section-title { margin-bottom: 10px; padding-bottom: 4px; }
    .entry { margin-bottom: 14px; }
    .entry-desc { margin-top: 2px; margin-bottom: 4px; }
    .entry li { margin-bottom: 1px; }
  }

  @page {
    margin: 0.5in 0.6in;
    size: letter;
  }
</style>

