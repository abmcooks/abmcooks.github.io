---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
  title="Resume — Basit Masood (ABM)"
  description="Basit Masood — Head of Product Design. 8 years in fintech. Founding designer at SadaPay (0→4M+ users) and ZAR (a16z-backed). Built 5 design systems, led teams of 12, products raised $90M+."
  canonicalUrl="https://abmcooks.github.io/resume/"
  ogTitle="Resume — Basit Masood (ABM)"
