---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="404 — ABM"
  description="Page not found."
  canonicalUrl="https://abmcooks.github.io/404"
  ogTitle="404 — ABM"
  ogDescription="Page not found."
  active="craft"
>

<style is:global>
    body {
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      min-height: 100dvh;
      padding-bottom: 0;
    }

    .c404 {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 32px;
      opacity: 0;
      animation: fadeUp 0.8s 0.2s forwards;
    }

    .num {
      font-family: var(--display);
      font-size: clamp(100px, 20vw, 220px);
      font-weight: 400;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      line-height: 1;
      color: var(--text);
      margin-bottom: 20px;
      user-select: none;
    }

    .msg {
      font-family: var(--body);
      font-size: clamp(18px, 3vw, 24px);
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }

    .sub {
      font-family: var(--serif);
      font-size: 15px;
      color: var(--text-dim);
      max-width: 360px;
      margin: 0 auto 40px;
      line-height: 1.7;
    }

    .back {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--body);
      font-size: 14px;
      font-weight: 600;
      color: white;
      text-decoration: none;
      background: var(--red);
      padding: 12px 28px;
      border-radius: 100px;
      box-shadow: 0 2px 24px rgba(204,41,54,0.35);
      transition: all 0.3s cubic-bezier(.23,1,.32,1);
    }
    .back:hover {
      box-shadow: 0 4px 32px rgba(204,41,54,0.55);
      transform: translateY(-2px) scale(1.03);
    }
    .back svg { width: 16px; height: 16px; transition: transform 0.3s; }
    .back:hover svg { transform: translateX(-3px); }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
</style>

  <div class="c404">
    <div class="num">404</div>
    <div class="msg">This page doesn't exist</div>
    <p class="sub">The page you're looking for may have been moved or never existed in the first place.</p>
    <a href="/" class="back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
      Back to Work
    </a>
  </div>

</PageLayout>
