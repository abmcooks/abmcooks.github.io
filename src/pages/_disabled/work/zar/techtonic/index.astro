---
import PageLayout from '../../../../layouts/PageLayout.astro';
---

<PageLayout
  title="Techtonic Design System — ABM"
  description="Techtonic Design System — From Brand Book to Production Code. A brand vision existed as ten beautiful PDFs. ABM built the system that ships it — 670 components, three platforms, zero drift."
  canonicalUrl="https://abmcooks.github.io/work/zar/techtonic/"
  ogTitle="Techtonic Design System — ABM"
  ogDescription="From Brand Book to Production Code. 670 components, three platforms, zero drift."
  active="craft"
>

<link rel="stylesheet" href="/assets/gate.css" slot="head" />
<script src="/assets/gate.js" defer slot="head"></script>

<style is:global>
  :root {
    --mono: 'JetBrains Mono', monospace;
    --accent: #C9A84E;
    --accent-light: #DBBF6A;
    --tanzanite: #5B8DEF;
    --serpentine: #4ADE80;
    --amethyst: #B1A8BD;
    --limestone: #C4BCB3;
  }



    /* --- CASE STUDY HERO --- */
    .cs-hero {
      position: relative;
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      padding: 160px 48px 80px;
    }

    .cs-hero-metric {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: var(--body);
      font-weight: 700;
      font-size: clamp(180px, 25vw, 360px);
      letter-spacing: -0.06em;
      line-height: 1;
      color: var(--accent);
      opacity: 0.08;
      pointer-events: none;
      user-select: none;
      white-space: nowrap;
    }

    .cs-hero-content {
      position: relative;
      z-index: 2;
      max-width: 720px;
      text-align: center;
      opacity: 0;
      animation: fu 0.8s 0.2s forwards;
    }

    .cs-hero-company {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .cs-hero-company::before,
    .cs-hero-company::after {
      content: '';
      width: 24px;
      height: 1px;
      background: rgba(201, 168, 78, 0.3);
    }

    .cs-logo {
      width: 24px;
      height: 24px;
      border-radius: 6px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0;
      text-transform: none;
      background: rgba(201, 168, 78, 0.15);
      color: var(--accent);
      border: 1px solid rgba(201, 168, 78, 0.12);
      overflow: hidden;
    }

    .cs-logo img {
      height: 16px;
      width: auto;
      object-fit: contain;
    }

    .cs-hero h1 {
      font-family: var(--display);
      font-size: clamp(36px, 5vw, 56px);
      font-weight: 400;
      letter-spacing: 0.02em;
      line-height: 1.1;
      color: var(--text);
      margin-bottom: 20px;
      text-transform: uppercase;
    }

    .cs-hero-hook {
      font-family: var(--serif);
      font-size: 19px;
      font-weight: 400;
      color: var(--text-dim);
      line-height: 1.6;
      max-width: 600px;
      margin: 0 auto 32px;
      font-style: italic;
    }

    .cs-hero-meta {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
    }

    .cs-meta-pill {
      font-size: 11px;
      font-weight: 500;
      padding: 5px 14px;
      border-radius: 100px;
      color: var(--text-dim);
      border: 1px solid var(--card-border);
      background: var(--card-bg);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    /* --- BRAND STRIP --- */
    .cs-brand-strip {
      position: relative;
      border-top: 1px solid rgba(0, 0, 0, 0.08);
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
      padding: 64px 24px;
      text-align: center;
      background: var(--card-bg);
    }

    .cs-brand-words {
      font-family: var(--body);
      font-size: clamp(36px, 8vw, 72px);
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--text-dim);
      line-height: 1;
    }

    .cs-brand-words span {
      color: var(--accent);
    }

    .cs-brand-sub {
      font-family: var(--serif);
      font-size: 16px;
      color: var(--text-dim);
      max-width: 500px;
      margin: 24px auto 0;
      line-height: 1.7;
    }

    /* --- ARTICLE BODY --- */
    .article {
      position: relative;
      max-width: 720px;
      margin: 0 auto;
      padding: 0 32px;
    }

    .cs-section {
      margin-top: 72px;
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.8s cubic-bezier(.23, 1, .32, 1), transform 0.8s cubic-bezier(.23, 1, .32, 1);
    }

    .cs-section.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .cs-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .cs-label::before {
      content: '';
      width: 20px;
      height: 1px;
      background: var(--accent);
    }

    .cs-heading {
      font-family: var(--body);
      font-size: clamp(24px, 3.5vw, 32px);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: var(--text);
      margin-bottom: 20px;
    }

    .cs-subheading {
      font-family: var(--body);
      font-size: 20px;
      font-weight: 600;
      color: var(--text);
      margin-top: 48px;
      margin-bottom: 16px;
      letter-spacing: -0.01em;
    }

    .cs-

    .cs-body strong {
      color: var(--text);
      font-weight: 700;
    }

    .cs-body em {
      color: var(--text-dim);
      font-style: italic;
    }

    .cs-quote {
      margin: 36px 0;
      padding: 24px 28px;
      border-left: 2px solid var(--accent);
      background: rgba(201, 168, 78, 0.06);
      border-radius: 0 14px 14px 0;
    }

    .cs-quote p {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 400;
      font-style: italic;
      color: var(--text-dim);
      line-height: 1.7;
      margin: 0;
    }

    .cs-quote p strong {
      color: var(--text);
      font-weight: 700;
      font-style: normal;
    }

    .cs-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 16px;
      margin: 36px 0;
    }

    .cs-stat {
      padding: 20px;
      border-radius: 14px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
      text-align: center;
    }

    .cs-stat-num {
      font-family: var(--body);
      font-size: 28px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: -0.02em;
      line-height: 1;
    }

    .cs-stat-label {
      font-size: 12px;
      color: var(--text-dim);
      margin-top: 6px;
      line-height: 1.4;
    }

    .cs-visual {
      margin: 36px 0;
      border-radius: 16px;
      background: rgba(0, 0, 0, 0.04);
      border: 1px solid var(--card-border);
      overflow: hidden;
      position: relative;
    }

    .cs-visual-inner {
      aspect-ratio: 16/9;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      color: var(--text-dim);
      padding: 32px;
      text-align: center;
    }

    .cs-visual-caption {
      padding: 12px 20px;
      font-size: 12px;
      color: var(--text-dim);
      border-top: 1px solid var(--card-border);
    }

    .cs-compare {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 36px 0;
    }

    .cs-compare-side {
      padding: 24px;
      border-radius: 14px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .cs-compare-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .cs-compare-side:first-child .cs-compare-label {
      color: var(--text-muted);
    }

    .cs-compare-side:last-child .cs-compare-label {
      color: var(--accent);
    }

    .cs-compare-content {
      font-family: var(--serif);
      font-size: 14px;
      color: var(--text-dim);
      line-height: 1.7;
    }

    .cs-compare-content strong {
      color: var(--text);
      font-weight: 700;
    }

    .cs-steps {
      margin: 28px 0;
    }

    .cs-step {
      display: flex;
      gap: 16px;
      padding: 16px 0;
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    }

    .cs-step:last-child {
      border-bottom: none;
    }

    .cs-step-num {
      font-family: var(--body);
      font-size: 24px;
      font-weight: 700;
      color: var(--accent);
      line-height: 1;
      flex-shrink: 0;
      width: 36px;
    }

    .cs-step-content {
      flex: 1;
    }

    .cs-step-title {
      font-family: var(--body);
      font-size: 16px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 4px;
    }

    .cs-step-desc {
      font-family: var(--serif);
      font-size: 14px;
      color: var(--text-dim);
      line-height: 1.6;
    }

    .cs-list {
      margin: 16px 0 20px;
      padding-left: 0;
      list-style: none;
    }

    .cs-list li {
      font-family: var(--serif);
      font-size: 15px;
      color: var(--text-dim);
      line-height: 1.7;
      padding: 6px 0 6px 20px;
      position: relative;
    }

    .cs-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 14px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      opacity: 0.5;
    }

    .cs-list li strong {
      color: var(--text);
      font-weight: 700;
    }

    .cs-divider {
      width: 48px;
      height: 1px;
      background: rgba(0, 0, 0, 0.08);
      margin: 48px auto;
    }

    /* --- PRINCIPLE CARDS (2x2) --- */
    .cs-principle-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      margin: 36px 0;
    }

    .cs-principle-card {
      padding: 24px;
      border-radius: 14px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .cs-principle-num {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 12px;
    }

    .cs-principle-title {
      font-family: var(--body);
      font-size: 16px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 8px;
    }

    .cs-principle-desc {
      font-family: var(--serif);
      font-size: 13px;
      color: var(--text-dim);
      line-height: 1.6;
    }

    /* --- MINERAL SWATCHES --- */
    .cs-mineral-row {
      display: flex;
      gap: 12px;
      margin: 36px 0;
      flex-wrap: wrap;
    }

    .cs-mineral-swatch {
      flex: 1;
      min-width: 90px;
      padding: 20px 12px;
      text-align: center;
      border-radius: 14px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .cs-mineral-circle {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      margin: 0 auto 10px;
    }

    .cs-mineral-name {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 2px;
    }

    .cs-mineral-use {
      font-size: 10px;
      color: var(--text-dim);
    }

    /* --- ARCHITECTURE LAYERS --- */
    .cs-arch-layers {
      margin: 36px 0;
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid var(--card-border);
    }

    .cs-arch-layer {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 20px 24px;
      background: var(--card-bg);
      border-bottom: 1px solid var(--card-border);
    }

    .cs-arch-layer:last-child {
      border-bottom: none;
    }

    .cs-arch-tag {
      font-family: var(--mono);
      font-size: 10px;
      font-weight: 700;
      color: var(--accent);
      background: rgba(201, 168, 78, 0.1);
      padding: 4px 10px;
      border-radius: 6px;
      min-width: 100px;
      text-align: center;
    }

    .cs-arch-name {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
    }

    .cs-arch-desc {
      font-size: 12px;
      color: var(--text-dim);
      margin-left: auto;
    }

    /* --- PLATFORM COLUMNS --- */
    .cs-platform-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin: 36px 0;
    }

    .cs-platform-col {
      padding: 24px 20px;
      text-align: center;
      border-radius: 14px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .cs-platform-icon {
      font-size: 28px;
      margin-bottom: 12px;
    }

    .cs-platform-name {
      font-family: var(--body);
      font-size: 15px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 4px;
    }

    .cs-platform-status {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 8px;
    }

    .cs-platform-status.live {
      color: var(--serpentine);
    }

    .cs-platform-status.migrating {
      color: var(--tanzanite);
    }

    .cs-platform-desc {
      font-family: var(--serif);
      font-size: 12px;
      color: var(--text-dim);
      line-height: 1.5;
    }

    .cs-platform-shared {
      background: rgba(201, 168, 78, 0.06);
      border: 1px solid var(--card-border);
      border-radius: 14px;
      padding: 14px;
      text-align: center;
      margin-top: 8px;
    }

    .cs-platform-shared span {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      color: var(--accent);
    }

    /* --- CODE BLOCK --- */
    .cs-code-block {
      background: var(--text);
      border: 1px solid var(--card-border);
      border-radius: 14px;
      padding: 20px 24px;
      margin: 28px 0;
      font-family: var(--mono);
      font-size: 13px;
      color: rgba(248, 245, 240, 0.7);
      line-height: 1.8;
      overflow-x: auto;
    }

    .cs-code-block .cb-comment {
      color: rgba(248, 245, 240, 0.4);
    }

    .cs-code-block .cb-token {
      color: var(--accent);
    }

    .cs-code-block .cb-method {
      color: var(--tanzanite);
    }

    /* --- MIGRATION BAR --- */
    .cs-migration-bar {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
      border-radius: 14px;
      padding: 32px 24px;
      margin: 36px 0;
    }

    .cs-migration-labels {
      display: flex;
      justify-content: space-between;
    }

    .cs-migration-label {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .cs-migration-label.old {
      color: var(--text-muted);
    }

    .cs-migration-label.new {
      color: var(--accent);
    }

    .cs-migration-track {
      height: 4px;
      background: rgba(0, 0, 0, 0.06);
      border-radius: 2px;
      position: relative;
      margin: 24px 0;
    }

    .cs-migration-fill {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 100%;
      background: linear-gradient(90deg, var(--text-muted), var(--accent));
      border-radius: 2px;
    }

    .cs-migration-date {
      text-align: center;
      margin-top: 16px;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--text-dim);
    }

    .cs-migration-date span {
      color: var(--accent);
      font-weight: 700;
    }

    /* --- FLYWHEEL --- */
    .cs-flywheel {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
      border-radius: 14px;
      padding: 40px 24px;
      margin: 36px 0;
      text-align: center;
    }

    .cs-flywheel-ring {
      display: flex;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    .cs-flywheel-node {
      background: var(--bg);
      border: 1px solid var(--card-border);
      border-radius: 14px;
      padding: 16px 20px;
      min-width: 140px;
    }

    .cs-flywheel-node.primary {
      border-color: rgba(201, 168, 78, 0.4);
      background: rgba(201, 168, 78, 0.06);
    }

    .cs-flywheel-label {
      font-family: var(--body);
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
    }

    .cs-flywheel-sub {
      font-size: 10px;
      color: var(--text-dim);
      margin-top: 2px;
    }

    .cs-flywheel-arrow {
      color: var(--text-muted);
      font-size: 18px;
      display: flex;
      align-items: center;
    }

    /* --- IMPACT LIST --- */
    .cs-impact-list {
      list-style: none;
      margin: 28px 0;
      padding: 0;
    }

    .cs-impact-list li {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
      font-family: var(--serif);
      font-size: 15px;
      color: var(--text-dim);
      line-height: 1.6;
    }

    .cs-impact-list li:last-child {
      border-bottom: none;
    }

    .cs-impact-list li::before {
      content: '';
      width: 6px;
      height: 6px;
      flex-shrink: 0;
      background: var(--accent);
      border-radius: 50%;
      margin-top: 8px;
    }

    .cs-impact-list li strong {
      color: var(--text);
      font-weight: 700;
    }

    /* Learning cards */
    .cs-learnings {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin: 32px 0;
    }

    .cs-learning {
      display: flex;
      gap: 20px;
      padding: 24px;
      border-radius: 14px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
      transition: border-color 0.3s;
    }

    .cs-learning:hover {
      border-color: rgba(201, 168, 78, 0.3);
    }

    .cs-learning-num {
      font-family: var(--body);
      font-size: 32px;
      font-weight: 700;
      color: rgba(201, 168, 78, 0.25);
      line-height: 1;
      flex-shrink: 0;
    }

    .cs-learning-content {
      flex: 1;
    }

    .cs-learning-title {
      font-family: var(--body);
      font-size: 17px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 6px;
      letter-spacing: -0.01em;
    }

    .cs-learning-desc {
      font-family: var(--serif);
      font-size: 14px;
      color: var(--text-dim);
      line-height: 1.7;
    }

    /* --- CASE NAV --- */
    .cs-nav {
      position: relative;
      max-width: 720px;
      margin: 80px auto 0;
      padding: 0 32px;
      display: flex;
      justify-content: space-between;
      gap: 16px;
    }

    .cs-nav-link {
      display: flex;
      flex-direction: column;
      gap: 4px;
      text-decoration: none;
      padding: 20px 24px;
      border-radius: 14px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
      transition: all 0.3s;
      flex: 1;
    }

    .cs-nav-link:hover {
      border-color: rgba(201, 168, 78, 0.3);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    }

    .cs-nav-link:last-child {
      text-align: right;
    }

    .cs-nav-dir {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .cs-nav-title {
      font-family: var(--body);
      font-size: 16px;
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.01em;
    }

    /* --- ANIMATIONS --- */

    /* --- RESPONSIVE --- */
    @media (max-width: 900px) {
      .cs-hero {
        padding: 140px 24px 60px;
        min-height: 60vh;
      }

      .cs-hero-metric {
        font-size: 140px;
      }

      .article {
        padding: 0 20px;
      }

      .cs-compare {
        grid-template-columns: 1fr;
      }

      .cs-platform-grid {
        grid-template-columns: 1fr;
      }

      .cs-nav {
        padding: 0 20px;
      }

      .cs-arch-layer {
