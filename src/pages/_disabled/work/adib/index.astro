---
import PageLayout from '../../../layouts/PageLayout.astro';
---

<PageLayout
  title="ADIB — ABM"
  description="ABM at ADIB — Rescued chaotic design system, shipped Open Banking UX and Visa Direct remittances. First bank worldwide with 11B+ payment endpoints."
  canonicalUrl="https://abmcooks.github.io/work/adib/"
  ogTitle="ADIB — ABM"
  ogDescription="Design system rescue. Open Banking. 11B+ endpoints globally."
  active="craft"
>

<style is:global>
    /* ─── BACK LINK ─── */
    .back-link {
      position: fixed;
      top: 64px;
      left: 48px;
      z-index: 100;
      font-family: var(--body);
      font-size: 14px;
      font-weight: 500;
      color: var(--text-dim);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: var(--text);
    }

    /* ─── WRAPPER ─── */
    .wrap {
      position: relative;
      z-index: 2;
      max-width: 900px;
      margin: 0 auto;
      padding: 0 48px;
    }

    /* ─── HERO SECTION ─── */
    .hero {
      position: relative;
      z-index: 2;
      padding: 180px 0 80px;
      text-align: center;
      opacity: 0;
      animation: fu 0.8s 0.1s forwards;
    }

    .co-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      margin-bottom: 24px;
      opacity: 0;
      animation: fu 0.5s 0.3s forwards;
    }

    .co-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #4A7BF7;
      box-shadow: 0 0 12px rgba(74, 123, 247, 0.4);
    }

    .co-tenure {
      font-family: var(--body);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #4A7BF7;
    }

    .co-name {
      font-family: var(--display);
      font-size: clamp(64px, 10vw, 120px);
      font-weight: 400;
      line-height: 1;
      letter-spacing: 0.04em;
      color: var(--text);
      text-transform: uppercase;
      margin-bottom: 20px;
      opacity: 0;
      animation: fu 0.7s 0.4s forwards;
    }

    .co-links {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-top: 4px;
      opacity: 0;
      animation: fu 0.6s 0.5s forwards;
    }

    .co-link {
      display: flex;
      align-items: center;
      gap: 5px;
      font-family: var(--body);
      font-size: 12px;
      font-weight: 500;
      color: var(--text-dim);
      text-decoration: none;
      padding: 5px 12px;
      border-radius: 100px;
      border: 1px solid rgba(74, 123, 247, 0.2);
      background: rgba(74, 123, 247, 0.06);
      transition: all 0.3s;
    }

    .co-link:hover {
      color: #4A7BF7;
      border-color: rgba(74, 123, 247, 0.4);
      background: rgba(74, 123, 247, 0.1);
    }

    .co-link svg {
      flex-shrink: 0;
    }

    /* ─── SECTION STYLES ─── */
    .section-label {
      font-family: var(--body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #4A7BF7;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .section-label::before {
      content: '';
      width: 24px;
      height: 1px;
      background: #4A7BF7;
    }

    /* ─── OVERVIEW ─── */
    .overview { padding: 0 0 0; }

    .overview-brief {
      font-family: var(--serif);
      font-size: 19px;
      font-weight: 400;
      color: var(--text-dim);
      line-height: 1.8;
      max-width: 750px;
    }

    .overview-brief strong {
      color: var(--text);
      font-weight: 700;
    }

    .overview-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 18px;
    }

    .ov-pill {
      font-family: var(--body);
      font-size: 11px;
      font-weight: 500;
      padding: 4px 12px;
      border-radius: 100px;
      color: #4A7BF7;
      border: 1px solid rgba(74, 123, 247, 0.2);
      background: rgba(74, 123, 247, 0.06);
    }

    /* ─── STATS ─── */
    .stats-inline {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      margin-top: 28px;
      padding: 24px 0;
      border-top: 1px solid rgba(0, 0, 0, 0.08);
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    }

    .si { text-align: center; position: relative; }

    .si+.si::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 1px;
      height: 28px;
      background: rgba(0, 0, 0, 0.08);
    }

    .si-num {
      font-family: var(--body);
      font-size: clamp(22px, 2.8vw, 30px);
      font-weight: 700;
      color: #4A7BF7;
      letter-spacing: -0.02em;
      line-height: 1;
    }

    .si-num-text {
      font-family: var(--body);
      font-size: 20px;
      font-weight: 700;
      color: #4A7BF7;
      letter-spacing: -0.02em;
      line-height: 1;
    }

    .si-label {
      font-family: var(--body);
      font-size: 11px;
      color: var(--text-muted);
      font-weight: 500;
      margin-top: 4px;
    }

    /* ─── TESTIMONIAL ─── */
    .testimonial {
      padding: 24px 28px;
      border-left: 2px solid #4A7BF7;
      background: var(--card-bg);
      border-radius: 0 12px 12px 0;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .testimonial p {
      font-family: var(--serif);
      font-size: 16px;
      font-weight: 400;
      font-style: italic;
      color: var(--text-dim);
      line-height: 1.7;
      margin: 0;
    }

    .testimonial span {
      display: block;
      margin-top: 12px;
      font-family: var(--body);
      font-size: 13px;
      color: #4A7BF7;
    }

    /* ─── NDA NOTE ─── */
    .work-note-card {
      padding: 32px;
      border-radius: 16px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
      text-align: center;
    }

    .work-note-card p {
      font-family: var(--serif);
      font-size: 17px;
      font-weight: 400;
      color: var(--text-dim);
      line-height: 1.6;
    }

    .work-note-card p span {
      color: var(--text);
    }

    /* ─── DELAY CLASSES ─── */
    .rd1 { transition-delay: .08s; }
    .rd2 { transition-delay: .16s; }
    .rd3 { transition-delay: .24s; }
    .rd4 { transition-delay: .32s; }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .wrap { padding-left: 20px; padding-right: 20px; }
      .hero { padding: 140px 0 60px; }
      .stats-inline { grid-template-columns: 1fr 1fr; gap: 16px 0; }
      .si:nth-child(2)::before { display: none; }
      .co-links { flex-wrap: wrap; justify-content: center; }
    }

    @media (max-width: 768px) {
      .back-link { top: 24px; left: 24px; }
    }

    @media (max-width: 640px) {
      .co-name { font-size: 56px; }
    }
</style>

  <!-- BACK LINK -->
  <a href="/" class="back-link">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
      stroke-linejoin="round" width="16" height="16">
      <path d="M19 12H5" />
      <path d="M12 19l-7-7 7-7" />
    </svg>
    Back
  </a>

  <!-- HERO -->
  <div class="wrap">
    <section class="hero">
      <div class="co-meta">
        <div class="co-dot"></div>
        <span class="co-tenure">2024 — 2025</span>
      </div>
      <h1 class="co-name">ADIB</h1>
      <div class="co-links">
        <a href="https://adib.ae" class="co-link" target="_blank">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
            <path d="M6 3H3.5A1.5 1.5 0 002 4.5v8A1.5 1.5 0 003.5 14h8a1.5 1.5 0 001.5-1.5V10M10 2h4v4M7 9l7-7"
              stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Website
        </a>
        <a href="https://www.linkedin.com/company/abu-dhabi-islamic-bank/posts/?feedView=all" class="co-link"
          target="_blank">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
            <path d="M4.5 10.5c0-1 2-1.5 3.5-1.5s3.5.5 3.5 1.5M8 7.5a2 2 0 100-4 2 2 0 000 4z" stroke="currentColor"
              stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
            <rect x="1" y="1" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.3" />
          </svg>
          LinkedIn
        </a>
        <a href="https://www.instagram.com/adib_bank/" class="co-link" target="_blank">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
            <rect x="1.5" y="1.5" width="13" height="13" rx="3.5" stroke="currentColor" stroke-width="1.3" />
            <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.3" />
            <circle cx="11.8" cy="4.2" r="0.8" fill="currentColor" />
          </svg>
          Instagram
        </a>
      </div>
    </section>

    <!-- OVERVIEW -->
    <section class="overview reveal">
      <p class="overview-brief">
        <strong>ADIB&rsquo;s design system was chaotic</strong> &mdash; inconsistent components, no atomic structure,
        engineers interpreting specs differently across teams. I came in to fix it. Rebuilt the system from chaotic to
        atomic, established design governance, and created documentation that engineering teams actually followed.
      </p>
      <p class="overview-brief" style="margin-top:16px;">
        Alongside the system rescue, I shipped two major products: the <strong>Open Banking experience</strong> (built
        from zero with Lean Technologies) and <strong>Remit!</strong> &mdash; a Visa Direct remittance product that made
        ADIB the first bank worldwide to offer <strong>11+ billion payment endpoints</strong>. Enterprise banking,
        regulatory constraints, stakeholder complexity &mdash; a different kind of design challenge from startup speed.
      </p>
      <div class="overview-pills">
        <span class="ov-pill">Lead Product Designer</span>
        <span class="ov-pill">Design System Rescue</span>
        <span class="ov-pill">Open Banking</span>
        <span class="ov-pill">Design Governance</span>
      </div>
      <div class="stats-inline">
        <div class="si">
          <div class="si-num" data-t="1" data-s="M+">0</div>
          <div class="si-label">App users</div>
        </div>
        <div class="si">
          <div class="si-num" data-t="11" data-s="B+">0</div>
          <div class="si-label">Endpoints (first globally)</div>
        </div>
        <div class="si">
          <div class="si-num" data-p="#" data-t="1" data-s="">0</div>
          <div class="si-label">Islamic bank in UAE</div>
        </div>
        <div class="si">
          <div class="si-num-text">Open Banking</div>
          <div class="si-label">Launched</div>
        </div>
      </div>

      <!-- TESTIMONIAL -->
      <div style="margin-top:40px;">
        <div class="testimonial">
          <p>&ldquo;What stood out most was his ability to engage with stakeholders at all levels &mdash; thoughtfully
            considering feedback, incorporating diverse perspectives, and articulating his own insights in a clear and
            structured manner.&rdquo;</p>
          <span>&mdash; Daniel Young, Head of Digital Products at ADIB</span>
        </div>
      </div>
    </section>
  </div>

  <!-- NDA NOTE -->
  <section class="reveal" style="max-width:900px;margin:48px auto 0;padding:0 48px;">
    <div class="work-note-card">
      <p>
        Detailed case studies for ADIB work are under NDA.<br>
        <span>Happy to discuss the approach and process in person.</span>
      </p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer style="max-width:900px;margin:80px auto 0;padding:0 48px;">
    <div
      style="padding-top:24px;border-top:1px solid rgba(0,0,0,0.08);display:flex;justify-content:space-between;font-size:12px;color:var(--text-muted);">
      <span>&copy; 2026 ABM</span>
      <span>Designed with intention</span>
    </div>
  </footer>

</PageLayout>
