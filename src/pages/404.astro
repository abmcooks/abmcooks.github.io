---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base title="404 — Page Not Found">

<div class="four-wrap">
  <div class="four-content">
    <p class="four-code">404</p>
    <h1 class="four-title">WRONG TURN.</h1>
    <p class="four-desc">This page doesn't exist — but the rest of the portfolio does.</p>
    <div class="four-links">
      <a href="/" class="four-link four-link--primary"><i class="ph-bold ph-house-simple"></i> Home</a>
      <a href="/stories" class="four-link">Stories</a>
      <a href="/about" class="four-link">About</a>
      <a href="/resume" class="four-link">Resume</a>
    </div>
  </div>
  <div class="four-dot"></div>
</div>

<style>
  .four-wrap {
    min-height: 100vh; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    background: var(--color-depth); padding: 40px 24px;
    text-align: center;
  }
  .four-content { max-width: 480px; }
  .four-code {
    font-family: var(--font-display); font-size: clamp(100px, 20vw, 200px);
    font-weight: 400; line-height: 0.85; text-transform: uppercase;
    color: var(--color-white-06);
    margin-bottom: 16px;
  }
  .four-title {
    font-family: var(--font-display); font-size: clamp(28px, 4vw, 48px);
    font-weight: 400; line-height: 1.05; text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: 16px;
  }
  .four-desc {
    font-family: var(--font-body); font-size: 18px; font-weight: 400;
    line-height: 1.6; color: var(--color-white-50);
    margin-bottom: 40px;
  }
  .four-links {
    display: flex; align-items: center; justify-content: center;
    gap: 16px; flex-wrap: wrap;
  }
  .four-link {
    font-family: var(--font-heading); font-size: 15px; font-weight: 500;
    color: var(--color-white-80); text-decoration: none;
    padding: 12px 24px; border-radius: 0.5em;
    border: 1px solid var(--color-white-12);
    display: inline-flex; align-items: center; gap: 8px;
    transition: color 0.2s, border-color 0.2s;
  }
  .four-link:hover { color: var(--color-rose); border-color: var(--color-rose); }
  .four-link--primary {
    background: var(--color-rose); border-color: var(--color-rose);
    color: var(--color-white);
  }
  .four-link--primary:hover {
    background: transparent; color: var(--color-rose);
  }
  .four-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--color-rose);
    box-shadow: 0 0 12px 4px rgba(225, 29, 72, 0.35);
    margin-top: 64px;
  }
</style>

</Base>
