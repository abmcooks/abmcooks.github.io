---
import Base from '../../layouts/Base.astro';
import Loader from '../../components/Loader.astro';
import Cursor from '../../components/Cursor.astro';
import Nav from '../../components/Nav.astro';
import FsMenu from '../../components/FsMenu.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import '../../styles/stories.css';
---

<Base title="Writing — Basit Masood" description="Essays, opinions, and things I wish someone told me earlier — on design leadership, AI, hiring, and the systems behind product work.">

<script is:inline>
  (function(){
    var apply = function(){ document.body && document.body.classList.add('page-light'); };
    var clear = function(){ document.body && document.body.classList.remove('page-light'); };
    apply();
    document.addEventListener('astro:page-load', apply);
    document.addEventListener('astro:after-swap', apply);
    document.addEventListener('astro:before-swap', clear);
  })();
</script>

<Loader />
<Cursor />
<Nav active="writing" />
<FsMenu />

<!-- HERO -->
<section class="wr2-hero">
  <div class="wr2-hero-inner">
    <p class="wr2-hero-kicker">Essays · 2025 – Present</p>
    <h1 class="wr2-hero-title">Notes.</h1>
    <p class="wr2-hero-sub">Opinions, lessons, and things I wish someone had told me earlier — about design leadership, AI, hiring, and the systems behind product work.</p>
  </div>
</section>

<!-- ARTICLE LIST -->
<section class="wr2-list">
  <p class="wr2-list-label">All articles · 4</p>

  <a href="/writing/ai-didnt-kill-the-designers-job" class="wr2-row">
    <span class="wr2-row-date">March 2026</span>
    <div class="wr2-row-content">
      <h2 class="wr2-row-title">AI didn't kill the designer's job.</h2>
      <p class="wr2-row-excerpt">Design isn't going anywhere — but the designers who refuse to evolve might.</p>
    </div>
    <span class="wr2-row-read">5 min read</span>
    <span class="wr2-row-arrow">→</span>
  </a>

  <a href="/writing/the-1-12-ratio" class="wr2-row">
    <span class="wr2-row-date">February 2026</span>
    <div class="wr2-row-content">
      <h2 class="wr2-row-title">The 1:12 ratio.</h2>
      <p class="wr2-row-excerpt">Out of every twelve candidates, only one gets through. Here's what I look for — and why portfolios aren't the answer.</p>
    </div>
    <span class="wr2-row-read">4 min read</span>
    <span class="wr2-row-arrow">→</span>
  </a>

  <a href="/writing/design-systems-that-outlast" class="wr2-row">
    <span class="wr2-row-date">January 2026</span>
    <div class="wr2-row-content">
      <h2 class="wr2-row-title">Design systems that outlast their designer.</h2>
      <p class="wr2-row-excerpt">Nukta, Techtonic, and the quiet discipline of building a system the next person can run without you in the room.</p>
    </div>
    <span class="wr2-row-read">6 min read</span>
    <span class="wr2-row-arrow">→</span>
  </a>

  <a href="/writing/watching-merchants" class="wr2-row">
    <span class="wr2-row-date">December 2025</span>
    <div class="wr2-row-content">
      <h2 class="wr2-row-title">Watching merchants ignore our product.</h2>
      <p class="wr2-row-excerpt">Standing in shops for hours taught me more than any moderated user test ever could.</p>
    </div>
    <span class="wr2-row-read">4 min read</span>
    <span class="wr2-row-arrow">→</span>
  </a>
</section>

<Footer />

<script>
  function initWriting() {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('revealed'); io.unobserve(e.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
    }
  }
  initWriting();
  document.addEventListener('astro:page-load', initWriting);
</script>

</Base>
