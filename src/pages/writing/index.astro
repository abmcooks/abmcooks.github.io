---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
  title="Writing — ABM"
  description="Writing by ABM (Basit Masood) — Notes on design leadership, fintech UX, building teams, and emerging markets."
  canonicalUrl="https://abmcooks.github.io/writing/"
  ogTitle="Writing — ABM"
  ogDescription="Notes on design leadership, fintech UX, building teams, and emerging markets."
  active="thoughts"
>

<style is:global>
    /* ─── HERO ─── */
    .hero {
      position: relative;
      z-index: 2;
      min-height: 50vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 140px 48px 40px;
      text-align: center;
    }

    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 600px;
      opacity: 0;
      animation: fu 0.8s 0.2s forwards;
    }

    .hero-label {
      font-family: var(--body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .hero-label::before,
    .hero-label::after {
      content: '';
      width: 24px;
      height: 1px;
      background: rgba(204, 41, 54, 0.3);
    }

    .hero h1 {
      font-family: var(--display);
      font-size: clamp(40px, 6vw, 60px);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.05;
      color: var(--text);
      margin-bottom: 20px;
    }

    .hero h1 .accent {
      color: var(--red);
    }

    .hero-sub {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 400;
      color: var(--text-dim);
      line-height: 1.6;
      letter-spacing: -0.01em;
      max-width: 480px;
      margin: 0 auto;
    }

    /* ─── WRAP ─── */
    .wrap {
      position: relative;
      z-index: 2;
      max-width: 800px;
      margin: 0 auto;
      padding: 0 48px;
    }

    /* ─── SECTION LABEL ─── */
    .section-label {
      font-family: var(--body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .section-label::before {
      content: '';
      width: 24px;
      height: 1px;
      background: var(--text-muted);
    }

    /* ─── ARTICLE LIST ─── */
    .articles {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-top: 20px;
    }

    .article-row {
      display: flex;
      align-items: flex-start;
      gap: 24px;
      padding: 28px 0;
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
      text-decoration: none;
      color: inherit;
      transition: all 0.3s;
    }

    .article-row:first-child {
      padding-top: 0;
    }

    .article-row:last-child {
      border-bottom: none;
    }

    .article-row:hover {
      padding-left: 8px;
    }

    .ar-date {
      font-family: var(--body);
      font-size: 12px;
      font-weight: 500;
      color: var(--text-muted);
      white-space: nowrap;
      min-width: 80px;
      padding-top: 4px;
    }

    .ar-content {
      flex: 1;
    }

    .ar-title {
      font-family: var(--body);
      font-size: 19px;
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.01em;
      line-height: 1.3;
      margin-bottom: 6px;
      transition: color 0.3s;
    }

    .article-row:hover .ar-title {
      color: var(--red);
    }

    .ar-desc {
      font-family: var(--serif);
      font-size: 14px;
      color: var(--text-dim);
      line-height: 1.6;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .ar-tags {
      display: flex;
      gap: 6px;
      margin-top: 10px;
    }

    .ar-tag {
      font-family: var(--body);
      font-size: 10px;
      font-weight: 500;
      padding: 3px 10px;
      border-radius: 100px;
      color: var(--text-muted);
      border: 1px solid rgba(0, 0, 0, 0.08);
      background: rgba(0, 0, 0, 0.03);
      transition: border-color 0.3s, color 0.3s;
    }

    .article-row:hover .ar-tag {
      border-color: rgba(204, 41, 54, 0.15);
      color: var(--text);
    }

    .ar-arrow {
      flex-shrink: 0;
      padding-top: 6px;
      color: var(--text-muted);
      opacity: 0;
      transform: translateX(-6px);
      transition: all 0.35s cubic-bezier(.23, 1, .32, 1);
    }

    .article-row:hover .ar-arrow {
      opacity: 1;
      transform: translateX(0);
    }

    /* ─── FEATURED ARTICLE ─── */
    .featured {
      display: block;
      padding: 32px;
      border-radius: 16px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      text-decoration: none;
      color: inherit;
      position: relative;
      overflow: hidden;
      transition: all 0.4s cubic-bezier(.23, 1, .32, 1);
      margin-bottom: 48px;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .featured:hover {
      border-color: rgba(204, 41, 54, 0.2);
      transform: translateY(-4px);
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
    }

    .featured-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--body);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 16px;
      padding: 4px 12px;
      border-radius: 100px;
      background: rgba(204, 41, 54, 0.06);
      border: 1px solid rgba(204, 41, 54, 0.12);
    }

    .featured-badge::before {
      content: '';
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--red);
      box-shadow: 0 0 8px rgba(204, 41, 54, 0.5);
    }

    .featured-title {
      font-family: var(--body);
      font-size: clamp(22px, 3vw, 28px);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: var(--text);
      margin-bottom: 10px;
      transition: color 0.3s;
    }

    .featured:hover .featured-title {
      color: var(--red);
    }

    .featured-desc {
      font-family: var(--serif);
      font-size: 15px;
      color: var(--text-dim);
      line-height: 1.7;
      max-width: 580px;
      margin-bottom: 16px;
    }

    .featured-meta {
      display: flex;
      align-items: center;
      gap: 16px;
      font-family: var(--body);
      font-size: 12px;
      color: var(--text-muted);
    }

    .featured-meta span {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .wrap {
        padding-left: 20px;
        padding-right: 20px;
      }

      .hero {
        padding: 120px 24px 32px;
      }

      .article-row {
        flex-direction: column;
        gap: 4px;
      }

      .ar-date {
        min-width: auto;
        padding-top: 0;
      }
    }

    @media (max-width: 640px) {
      .hero h1 {
        font-size: 36px;
      }
    }
</style>

  <!-- HERO -->
  <div class="hero">
    <div class="hero-inner">
      <div class="hero-label">Writing</div>
      <h1>Thinking<br><span style="white-space:nowrap">out <span class="accent">loud.</span></span></h1>
      <p class="hero-sub">Notes on design leadership, fintech UX, building teams, and the things I&rsquo;m figuring out
        along the way.</p>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="wrap">

    <!-- FEATURED -->
    <section class="reveal">
      <a href="/writing/the-1-12-ratio/" class="featured">
        <div class="featured-badge">Featured</div>
        <div class="featured-title">The 1:12 ratio &mdash; what being the only designer taught me</div>
        <p class="featured-desc">Lessons from being the first and only designer at two startups, surrounded by engineers
          who needed design decisions faster than I could make them.</p>
        <div class="featured-meta">
          <span>Dec 2025</span>
          <span>&middot;</span>
          <span>7 min read</span>
          <span>&middot;</span>
          <span>Leadership, Startups</span>
        </div>
      </a>
    </section>

    <!-- ALL ARTICLES -->
    <section class="reveal">
      <div class="section-label">All Articles</div>
      <div class="articles">

        <a href="/writing/the-1-12-ratio/" class="article-row">
          <div class="ar-date">Dec 2025</div>
          <div class="ar-content">
            <div class="ar-title">The 1:12 ratio &mdash; what being the only designer taught me</div>
            <div class="ar-desc">Lessons from being the first and only designer at two startups, surrounded by engineers
              who needed design decisions faster than I could make them.</div>
            <div class="ar-tags">
              <span class="ar-tag">Leadership</span>
              <span class="ar-tag">Startups</span>
            </div>
          </div>
          <div class="ar-arrow">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M4 12L12 4M12 4H6M12 4V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
          </div>
        </a>

        <a href="/writing/waitlist-gamification/" class="article-row">
          <div class="ar-date">Dec 2025</div>
          <div class="ar-content">
            <div class="ar-title">Gamified waitlists &mdash; turning anticipation into activation</div>
            <div class="ar-desc">How we used gamification mechanics to turn 700K waitlist signups into engaged power
              users at SadaPay &mdash; with zero paid acquisition.</div>
            <div class="ar-tags">
              <span class="ar-tag">Growth Design</span>
              <span class="ar-tag">Gamification</span>
            </div>
          </div>
          <div class="ar-arrow">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M4 12L12 4M12 4H6M12 4V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
          </div>
        </a>

      </div>
    </section>

  </div>

  <!-- FOOTER -->
  <footer style="max-width:900px;margin:80px auto 0;padding:0 48px;">
    <div
      style="padding-top:24px;border-top:1px solid rgba(0,0,0,0.08);display:flex;justify-content:space-between;font-size:12px;color:var(--text-muted);padding-bottom:80px;">
      <span>&copy; 2026 ABM</span><span>Designed with intention</span>
    </div>
  </footer>

</PageLayout>
