---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
  title="Contact — ABM"
  description="Get in touch with ABM (Basit Masood) — open to design leadership roles, advisory, consulting, and interesting conversations."
  canonicalUrl="https://abmcooks.github.io/contact/"
  ogTitle="Contact — ABM"
  ogDescription="Let's build something worth shipping."
  active="contact"
>

<style is:global>
    /* --- HERO --- */
    .hero {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 140px 48px 32px;
      text-align: center;
    }

    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 700px;
      opacity: 0;
      animation: fu 0.8s 0.2s forwards;
    }

    .hero-label {
      font-family: var(--body);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .hero-label::before,
    .hero-label::after {
      content: '';
      width: 24px;
      height: 1px;
      background: rgba(204, 41, 54, 0.4);
    }

    .hero h1 {
      font-family: var(--display);
      font-size: clamp(32px, 4.5vw, 48px);
      font-weight: 400;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      line-height: 1.05;
      color: var(--text);
      margin-bottom: 20px;
    }

    .hero h1 .accent {
      color: var(--red);
    }

    .hero-sub {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 400;
      color: var(--text-dim);
      line-height: 1.7;
      max-width: 520px;
      margin: 0 auto;
    }

    /* --- WRAP --- */
    .wrap {
      position: relative;
      z-index: 2;
      max-width: 800px;
      margin: 0 auto;
      padding: 0 48px;
    }

    /* --- CONTACT CARDS --- */
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-top: 20px;
    }

    .contact-card {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 28px;
      border-radius: var(--radius);
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
      text-decoration: none;
      color: inherit;
      transition: all 0.4s cubic-bezier(.23, 1, .32, 1);
      position: relative;
      overflow: hidden;
    }

    .contact-card:hover {
      border-color: rgba(0, 0, 0, 0.12);
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    }

    .contact-card.primary {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .cc-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(204, 41, 54, 0.1);
      border: 1px solid rgba(204, 41, 54, 0.2);
      color: var(--red);
      flex-shrink: 0;
      transition: all 0.3s;
    }

    .contact-card:hover .cc-icon {
      background: rgba(204, 41, 54, 0.18);
      border-color: rgba(204, 41, 54, 0.35);
    }

    .cc-label {
      font-family: var(--body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .cc-value {
      font-family: var(--body);
      font-size: 17px;
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.01em;
      transition: color 0.3s;
    }

    .contact-card:hover .cc-value {
      color: var(--red);
    }

    .cc-arrow {
      color: var(--text-dim);
      opacity: 0;
      transform: translateX(-6px);
      transition: all 0.35s cubic-bezier(.23, 1, .32, 1);
    }

    .contact-card:hover .cc-arrow {
      opacity: 1;
      transform: translateX(0);
    }

    /* --- LOCATION --- */
    .location {
      margin-top: 64px;
      display: flex;
      gap: 48px;
      padding: 32px;
      border-radius: var(--radius);
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    }

    .loc-block {
      flex: 1;
    }

    .loc-label {
      font-family: var(--body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 6px;
    }

    .loc-value {
      font-family: var(--body);
      font-size: 19px;
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.01em;
    }

    .loc-sub {
      font-family: var(--serif);
      font-size: 13px;
      color: var(--text-dim);
      margin-top: 2px;
    }

    /* --- FOOTER --- */
    footer {
      position: relative;
      z-index: 2;
      max-width: 800px;
      margin: 80px auto 0;
      padding: 0 48px;
    }

    .fb {
      padding-top: 24px;
      border-top: 1px solid rgba(0, 0, 0, 0.08);
      display: flex;
      justify-content: space-between;
      font-family: var(--body);
      font-size: 12px;
      color: var(--text-muted);
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 900px) {

      .wrap,
      footer {
        padding-left: 20px;
        padding-right: 20px;
      }

      .hero {
        padding: 120px 24px 32px;
      }

      .contact-grid {
        grid-template-columns: 1fr;
      }

      .contact-card.primary {
        flex-direction: column;
      }

      .location {
        flex-direction: column;
        gap: 24px;
      }
    }

    @media (max-width: 640px) {
      .hero h1 {
        font-size: 36px;
      }

      .fb {
        flex-direction: column;
        gap: 8px;
        text-align: center;
      }
    }
</style>

  <!-- HERO -->
  <div class="hero">
    <div class="hero-inner">
      <div class="hero-label">Get in touch</div>
      <h1>LET&rsquo;S <span class="accent">TALK.</span></h1>
      <p class="hero-sub">Open to conversations about design leadership, fintech UX, or building products for emerging
        markets.</p>
    </div>
  </div>

  <!-- CONTACT METHODS -->
  <div class="wrap">

    <section class="reveal">
      <div class="contact-grid">

        <!-- EMAIL (primary — spans full width) -->
        <a href="mailto:basitmasood999@gmail.com" class="contact-card primary">
          <div style="display:flex;align-items:center;gap:16px;">
            <div class="cc-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M3 5l7 5 7-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                  stroke-linejoin="round" />
                <rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5" />
              </svg>
            </div>
            <div>
              <div class="cc-label">Email</div>
              <div class="cc-value">basitmasood999@gmail.com</div>
            </div>
          </div>
          <div class="cc-arrow">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M5 15L15 5M15 5H8M15 5V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
          </div>
        </a>

        <!-- LINKEDIN -->
        <a href="https://linkedin.com/in/iabm" class="contact-card" target="_blank">
          <div class="cc-icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M4.5 7.5v6M4.5 4.5v.01M8 13.5v-3.75c0-1.25 1-2.25 2.25-2.25s2.25 1 2.25 2.25V13.5"
                stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              <rect x="1" y="1" width="16" height="16" rx="3" stroke="currentColor" stroke-width="1.3" />
            </svg>
          </div>
          <div class="cc-label">LinkedIn</div>
          <div class="cc-value">Connect with me</div>
        </a>

        <!-- WHATSAPP -->
        <a href="https://wa.me/971582071725" class="contact-card" target="_blank">
          <div class="cc-icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M9 1.5A7.5 7.5 0 002.1 12.6L1.5 16.5l3.9-.6A7.5 7.5 0 109 1.5z" stroke="currentColor"
                stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              <path
                d="M6.5 7.5c.2-.8.5-1 1-1s.8.5.9 1 .3 1.2-.2 2-.8 1-1.2 1.3c-.4.3-.9.7-1.5.7M8.2 9.5c.5.8 1.2 1.5 2 2 .5.3 1 .2 1.3 0s.5-.7.7-.7.7.3 1 .5.5.5.5.7-.2.7-.5 1"
                stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <div class="cc-label">WhatsApp</div>
          <div class="cc-value">Message me</div>
        </a>

        <!-- PHONE -->
        <a href="tel:+971582071725" class="contact-card">
          <div class="cc-icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path
                d="M6.6 8.2c.8 1.6 2 2.8 3.6 3.6l1.2-1.2c.2-.2.5-.3.7-.2 1 .3 2 .5 3 .5.3 0 .5.2.5.5v2.7c0 .3-.2.5-.5.5C7.8 14.6 2.4 9.2 2.4 3.1c0-.3.2-.5.5-.5H5.6c.3 0 .5.2.5.5 0 1 .2 2 .5 3 .1.2 0 .5-.2.7L5.2 8.2"
                stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <div class="cc-label">Call</div>
          <div class="cc-value">+971 58 207 1725</div>
        </a>

        <!-- GITHUB -->
        <a href="https://github.com/abmcooks" class="contact-card" target="_blank">
          <div class="cc-icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path
                d="M9 1.5C4.86 1.5 1.5 4.86 1.5 9c0 3.31 2.15 6.12 5.13 7.12.38.07.52-.16.52-.36v-1.26c-2.09.45-2.53-1.01-2.53-1.01-.34-.87-.83-1.1-.83-1.1-.68-.46.05-.45.05-.45.75.05 1.15.77 1.15.77.67 1.15 1.75.82 2.18.62.07-.48.26-.82.47-1.01-1.67-.19-3.42-.83-3.42-3.72 0-.82.29-1.49.77-2.02-.08-.19-.33-.96.07-1.99 0 0 .63-.2 2.06.77a7.17 7.17 0 013.75 0c1.43-.97 2.06-.77 2.06-.77.4 1.03.15 1.8.07 1.99.48.53.77 1.2.77 2.02 0 2.9-1.76 3.53-3.43 3.72.27.23.51.69.51 1.39v2.07c0 .2.14.43.52.36A7.5 7.5 0 009 1.5z"
                stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <div class="cc-label">GitHub</div>
          <div class="cc-value">abmcooks</div>
        </a>

      </div>
    </section>

    <!-- LOCATION -->
    <section class="location reveal" style="margin-top: 48px;">
      <div class="loc-block">
        <div class="loc-label">Based in</div>
        <div class="loc-value">Dubai, UAE</div>
        <div class="loc-sub">Open to remote &amp; relocation</div>
      </div>
      <div class="loc-block">
        <div class="loc-label">Timezone</div>
        <div class="loc-value">GMT+4</div>
        <div class="loc-sub">Overlap with EU, UK, and East Coast</div>
      </div>
      <div class="loc-block">
        <div class="loc-label">Response time</div>
        <div class="loc-value">&lt; 24 hours</div>
        <div class="loc-sub">Usually much faster</div>
      </div>
    </section>

  </div>

  <!-- FOOTER -->
  <footer class="reveal">
    <div class="fb"><span>&copy; 2026 ABM</span><span>Designed with intention</span></div>
  </footer>

</PageLayout>
