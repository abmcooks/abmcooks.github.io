<script>
  function initConsulting() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Scroll reveal for any .reveal elements
    const reveals = document.querySelectorAll<HTMLElement>('.reveal');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    reveals.forEach(el => io.observe(el));

    if (prefersReducedMotion) {
      reveals.forEach(el => el.classList.add('revealed'));
    }

    // Problems scroll deck (existing)
    const problems = document.getElementById('csProblems');
    const slides = problems?.querySelectorAll('.cs2-problem-slide');
    const fill = document.getElementById('csProgressFill');
    if (problems && slides && slides.length && fill) {
      function updateProblems() {
        const rect = problems!.getBoundingClientRect();
        const viewport = window.innerHeight;
        const scrollStart = rect.top;
        const scrollRange = rect.height - viewport;
        if (scrollRange <= 0 || scrollStart > viewport) return;
        const progress = Math.max(0, Math.min(1, -scrollStart / scrollRange));
        (fill as HTMLElement).style.transform = `scaleX(${progress})`;
        const activeIndex = Math.min(slides!.length - 1, Math.floor(progress * slides!.length));
        slides!.forEach((s, i) => s.classList.toggle('is-active', i === activeIndex));
      }
      window.addEventListener('scroll', updateProblems, { passive: true });
      updateProblems();
    }

    // Process timeline step activation
    const steps = document.querySelectorAll<HTMLElement>('.cs3-step');
    const stepIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) e.target.classList.add('is-active');
      });
    }, { threshold: 0.4 });
    steps.forEach(s => stepIO.observe(s));

    // Magnetic CTA buttons — translate toward cursor within 120px
    document.querySelectorAll<HTMLElement>('.cs3-cta-link--primary').forEach(btn => {
      btn.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = btn.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = e.clientX - cx;
        const dy = e.clientY - cy;
        const dist = Math.hypot(dx, dy);
        if (dist < 120) {
          const strength = (120 - dist) / 120;
          btn.classList.add('is-magnetic');
          btn.style.transform = `translate(${dx * 0.2 * strength}px, ${dy * 0.2 * strength}px)`;
        }
      });
      btn.addEventListener('mouseleave', () => {
        btn.classList.remove('is-magnetic');
        btn.style.transform = '';
      });
    });

    // Click-to-copy email with toast
    const emailLinks = document.querySelectorAll<HTMLAnchorElement>('a[href^="mailto:"]');
    const toast = document.getElementById('copyToast');
    emailLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const email = link.href.replace('mailto:', '');
        navigator.clipboard?.writeText(email);
        if (toast) {
          toast.classList.add('is-visible');
          setTimeout(() => toast.classList.remove('is-visible'), 1500);
        }
      });
    });

    // Cursor-trail canvas on hero
    const canvas = document.getElementById('cs3HeroCanvas') as HTMLCanvasElement | null;
    if (canvas && !window.matchMedia('(prefers-reduced-motion: reduce)').matches && window.matchMedia('(pointer: fine)').matches) {
      const ctx = canvas.getContext('2d');
      if (ctx) {
        const hero = canvas.parentElement as HTMLElement;
        const dpr = Math.min(window.devicePixelRatio || 1, 2);

        function resize() {
          if (!hero || !canvas || !ctx) return;
          const rect = hero.getBoundingClientRect();
          canvas.width = Math.floor(rect.width * dpr);
          canvas.height = Math.floor(rect.height * dpr);
          canvas.style.width = rect.width + 'px';
          canvas.style.height = rect.height + 'px';
          ctx.scale(dpr, dpr);
        }
        resize();
        window.addEventListener('resize', resize);

        // Trail state
        type Pt = { x: number; y: number; life: number };
        const trails: Pt[] = [];
        let mouseX = -1, mouseY = -1, lastX = -1, lastY = -1;

        hero.addEventListener('mousemove', (e) => {
          const rect = hero.getBoundingClientRect();
          mouseX = e.clientX - rect.left;
          mouseY = e.clientY - rect.top;
          if (lastX < 0) { lastX = mouseX; lastY = mouseY; }
          // Interpolate points between last and current to smooth fast movements
          const dx = mouseX - lastX;
          const dy = mouseY - lastY;
          const dist = Math.hypot(dx, dy);
          const steps = Math.max(1, Math.floor(dist / 6));
          for (let i = 1; i <= steps; i++) {
            trails.push({
              x: lastX + (dx * i) / steps,
              y: lastY + (dy * i) / steps,
              life: 1,
            });
          }
          lastX = mouseX; lastY = mouseY;
          // Cap trail length
          if (trails.length > 120) trails.splice(0, trails.length - 120);
        });

        hero.addEventListener('mouseleave', () => {
          lastX = -1; lastY = -1;
        });

        function render() {
          if (!ctx || !canvas) return;
          ctx.clearRect(0, 0, canvas.width / dpr, canvas.height / dpr);

          // Decay trail points
          for (let i = trails.length - 1; i >= 0; i--) {
            trails[i].life -= 0.012;
            if (trails[i].life <= 0) trails.splice(i, 1);
          }

          // Render as flowing curve
          if (trails.length > 1) {
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            for (let i = 1; i < trails.length; i++) {
              const p = trails[i];
              const prev = trails[i - 1];
              const alpha = Math.max(0, p.life) * 0.55;
              ctx.strokeStyle = `rgba(225, 29, 72, ${alpha})`;
              ctx.lineWidth = 2 + Math.max(0, p.life) * 6;
              ctx.shadowColor = 'rgba(225, 29, 72, 0.8)';
              ctx.shadowBlur = 12 * p.life;
              ctx.beginPath();
              ctx.moveTo(prev.x, prev.y);
              ctx.lineTo(p.x, p.y);
              ctx.stroke();
            }
            ctx.shadowBlur = 0;
          }

          requestAnimationFrame(render);
        }
        render();
      }
    }

    // Testimonial 3D tilt — rotateX/rotateY based on cursor position
    document.querySelectorAll<HTMLElement>('.cs3-testi-card').forEach(card => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = `perspective(1000px) rotateX(${-y * 6}deg) rotateY(${x * 6}deg) scale(1.02)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
      });
    });
  }
  initConsulting();
  document.addEventListener('astro:page-load', initConsulting);
</script>

</Base>
