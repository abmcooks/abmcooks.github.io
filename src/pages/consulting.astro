<script>
  function initConsulting() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Scroll reveal for any .reveal elements
    const reveals = document.querySelectorAll<HTMLElement>('.reveal');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    reveals.forEach(el => io.observe(el));

    if (prefersReducedMotion) {
      reveals.forEach(el => el.classList.add('revealed'));
    }

    // Problems scroll deck (existing)
    const problems = document.getElementById('csProblems');
    const slides = problems?.querySelectorAll('.cs2-problem-slide');
    const fill = document.getElementById('csProgressFill');
    if (problems && slides && slides.length && fill) {
      function updateProblems() {
        const rect = problems!.getBoundingClientRect();
        const viewport = window.innerHeight;
        const scrollStart = rect.top;
        const scrollRange = rect.height - viewport;
        if (scrollRange <= 0 || scrollStart > viewport) return;
        const progress = Math.max(0, Math.min(1, -scrollStart / scrollRange));
        (fill as HTMLElement).style.transform = `scaleX(${progress})`;
        const activeIndex = Math.min(slides!.length - 1, Math.floor(progress * slides!.length));
        slides!.forEach((s, i) => s.classList.toggle('is-active', i === activeIndex));
      }
      window.addEventListener('scroll', updateProblems, { passive: true });
      updateProblems();
    }

    // Process timeline step activation
    const steps = document.querySelectorAll<HTMLElement>('.cs3-step');
    const stepIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) e.target.classList.add('is-active');
      });
    }, { threshold: 0.4 });
    steps.forEach(s => stepIO.observe(s));

    // Email click-to-copy with in-place label swap
    const ctaEmail = document.getElementById('cs4CtaEmail');
    if (ctaEmail) {
      const action = ctaEmail.querySelector<HTMLElement>('.cs4-cta-method-action');
      ctaEmail.addEventListener('click', (e) => {
        e.preventDefault();
        navigator.clipboard?.writeText('basitmasood999@gmail.com');
        if (action) {
          const copied = action.dataset.copied || 'Copied';
          const defaultText = action.dataset.default || action.textContent || 'Click to copy';
          action.textContent = copied;
          action.style.color = 'var(--color-rose)';
          setTimeout(() => {
            action.textContent = defaultText;
            action.style.color = '';
          }, 1400);
        }
      });
    }

  }
  initConsulting();
  document.addEventListener('astro:page-load', initConsulting);
</script>

